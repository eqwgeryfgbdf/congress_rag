# Copy this file to .env and fill in your values.
# .env is ignored by git.

OPENAI_API_KEY=sk-your-api-key
OPENAI_MODEL=gpt-5.5

# Optional chat defaults.
CONGRESS_RAG_FILE=data/rag/speeches.jsonl
CONGRESS_RAG_TOP_K=5

# Optional: override the default Traditional Chinese assistant instructions.
# OPENAI_INSTRUCTIONS=你是立法院逐字稿資料助理，請根據本機 RAG 內容回答。
